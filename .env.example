# ===== БД на Render =====
# На Render PostgreSQL автоматически генерирует URL
# Скопируй его из панели Render
DATABASE_URL=postgresql://user:password@host:5432/database

# ===== Telegram Bot =====
# BOT_TOKEN - токен твого admin бота (где получаешь уведомления об оплате)
BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefg

# BOT_CHAT_ID - твой ID в Telegram (где получаешь уведомления)
# Узнаешь у бота @userinfobot
BOT_CHAT_ID=123456789

# ===== VKURSE Pay =====
VKP_RATE=2.60

# ===== Сервер =====
DEBUG=False
HOST=0.0.0.0
PORT=8000
